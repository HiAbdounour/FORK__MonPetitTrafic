{
  "expo": {
    "name": "Mon Petit Trafic",
    "slug": "MonPetitTrafic",
    "version": "0.2.0.beta",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "monpetittrafic",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/logo.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#EEB27F",
        "foregroundImage": "./assets/images/logo_foreground.png",
        "backgroundImage": "",
        "monochromeImage": "./assets/images/logo_false_monochrom.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFDFAE",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
